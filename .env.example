DATABASE_URL=postgres://asset_user:asset_pass@localhost:5432/asset_ingest
RUST_LOG=asset_ingest_api=debug,tower_http=debug,sqlx=warn
PORT=3000
MAX_UPLOAD_BYTES=104857600

# Required. Generate one with: openssl rand -hex 32
API_KEY=

# Optional - both default sensibly if unset (10 req/s sustained, burst
# of 20). Uncomment to override.
# RATE_LIMIT_PER_SECOND=10
# RATE_LIMIT_BURST=20
